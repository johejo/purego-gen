{
  "schema_version": 2,
  "generator": {
    "lib_id": "mylib",
    "package": "mylibsys",
    "emit": [
      "func",
      "type"
    ],
    "parse": {
      "headers": {
        "kind": "local",
        "headers": [
          "mylib.h"
        ]
      }
    },
    "render": {
      "public_api": {
        "strip_prefix": "mylib_",
        "type_aliases": {
          "include": [
            "mylib_db",
            "mylib_stmt"
          ],
          "overrides": {
            "mylib_db": "DB"
          }
        },
        "wrappers": {
          "include": [
            "mylib_malloc",
            "mylib_free",
            {
              "pattern": "mylib_bind_.*"
            }
          ],
          "exclude": [
            "mylib_bind_text"
          ],
          "overrides": {
            "mylib_db_release_memory": "DBReleaseMemory"
          }
        }
      }
    }
  }
}
